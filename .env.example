# Copy to `.env` and fill in. The app loads `.env` automatically on startup.

# YouTube Data API v3 (required for search, metadata fixer, etc.)
API_KEY=your_youtube_data_api_key_here
# Optional second key for automatic failover when quota is exceeded:
# API_KEY_2=

# Optional aliases if you prefer (used only when API_KEY is unset):
# YOUTUBE_API_KEY=
# YT_API_KEY=

# Backblaze B2 (cloud upload / catalog) — see app/logic/b2_storage.py
# ENDPOINT_URL=
# B2_KEY_ID=
# B2_APPLICATION_KEY=
# BUCKET_NAME=
